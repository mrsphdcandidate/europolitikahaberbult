  <!-- Right Column: Recommended Articles -->
  <aside class="article-sidebar-right">
    <div class="sidebar-widget">
      <h3>ÖNERİLEN ANALİZLER</h3>
      <div class="recommended-list">
        <% if (relatedArticles && relatedArticles.length > 0) { %>
          <% relatedArticles.forEach(function(rel) { %>
            <a href="/haber/<%= rel.slug %>" class="rec-card">
              <% if (rel.cover_image) { %>
                <img src="<%= rel.cover_image %>" alt="<%= rel.title %>">
              <% } else { %>
                <div class="placeholder-img" style="background: linear-gradient(135deg, #1A1A1A 0%, #C53030 100%);"></div>
              <% } %>
              <div class="rec-title"><%= rel.title %></div>
              <div class="rec-meta"><%= formatDate(rel.published_at || rel.created_at) %></div>
            </a>
          <% }); %>
        <% } %>
        <!-- Mock placeholder cards to make layout look rich and full -->
        <% if (!relatedArticles || relatedArticles.length < 3) { %>
          <div class="rec-card">
            <div class="placeholder-img" style="background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);"></div>
            <div class="rec-title">Avrupa Birliği Dijital Euro Yarışında Son Virajda</div>
            <div class="rec-meta">Piyasalar · 3 dk okuma</div>
          </div>
          <div class="rec-card">
            <div class="placeholder-img" style="background: linear-gradient(135deg, #4a5568 0%, #2d3748 100%);"></div>
            <div class="rec-title">Enflasyon Rakamları Sonrası Borsa ve Kur Beklentileri</div>
            <div class="rec-meta">Makroekonomi · 5 dk okuma</div>
          </div>
        <% } %>
      </div>
    </div>
  </aside>

</div>

<% if (relatedArticles.length > 0) { %>
<!-- Related Articles -->
<div class="related-section">
  <div class="section-divider">
    <h2>DİĞER YAZILAR</h2>
  </div>
  <div class="related-grid">
    <% relatedArticles.forEach(function(relArticle) { %>
    <article class="article-card">
      <a href="/haber/<%= relArticle.slug %>" class="card-image-wrapper">
        <% if (relArticle.cover_image) { %>
          <img src="<%= relArticle.cover_image %>" alt="<%= relArticle.title %>" loading="lazy">
        <% } else { %>
          <div class="card-image-placeholder"></div>
        <% } %>
      </a>
      <div class="card-body">
        <% if (relArticle.category) { %>
          <span class="card-category"><%= relArticle.category %></span>
        <% } %>
        <h3 class="card-title">
          <a href="/haber/<%= relArticle.slug %>"><%= relArticle.title %></a>
        </h3>
        <% if (relArticle.excerpt) { %>
          <p class="card-excerpt"><%= truncate(relArticle.excerpt, 120) %></p>
        <% } %>
        <div class="card-footer">
          <span class="card-date"><%= formatDate(relArticle.published_at || relArticle.created_at) %></span>
          <a href="/haber/<%= relArticle.slug %>" class="card-read-more">DEVAMINI OKU →</a>
        </div>
      </div>
    </article>
    <% }); %>
  </div>
</div>
<% } %>

