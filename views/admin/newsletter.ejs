<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bülten Oluştur — EuroPolitika Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" aria-label="Menüyü aç">☰</button>
  <div class="sidebar-overlay"></div>

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <a href="/admin" class="sidebar-logo">
        <img src="/img/logo_dark.svg" alt="EuroPolitika Logo" class="sidebar-logo-img">
      </a>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-item">
        <span class="nav-icon">📊</span> Dashboard
      </a>
      <a href="/admin/haberler" class="nav-item">
        <span class="nav-icon">📰</span> Haberler
      </a>
      <a href="/admin/bulten-olustur" class="nav-item active">
        <span class="nav-icon">✉️</span> Bülten Oluştur
      </a>
      <a href="/admin/aboneler" class="nav-item">
        <span class="nav-icon">👥</span> Aboneler
      </a>
      <a href="/" class="nav-item" target="_blank">
        <span class="nav-icon">🌐</span> Siteye Git
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="nav-item logout">
        <span class="nav-icon">🚪</span> Çıkış
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>Haftalık/Günlük Bülten Oluştur</h1>
    </div>

    <div class="admin-content" style="max-width: 800px;">
      
      <div class="card">
        <div class="card-header">
          <h2>Bülten İçerik Kaynakları</h2>
        </div>
        <div class="card-body">
          <p style="color: #718096; font-size: 14px; margin-bottom: 24px; line-height: 1.5;">
            Bültene eklemek istediğiniz haber linklerini veya kendi yazdığınız düz metinleri/paragrafları girin. AI bu içeriklerin tamamını tek bir bülten (digest) şeklinde birleştirecek, linklerdeki görselleri kazıyıp kalıcı bir kapak kolajı ürettikten sonra düzenlemeniz için editöre aktaracaktır.
          </p>

          <form id="newsletterForm" style="display: flex; flex-direction: column; gap: 16px;">
            <!-- Bülten Başlığı (Opsiyonel) -->
            <div class="title-row" style="display: flex; flex-direction: column; gap: 6px; background: #FFF; padding: 12px; border-radius: 8px; border: 1px solid #E2E8F0;">
              <span style="font-weight: 700; color: #4A5568; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Bülten Başlığı (Opsiyonel)</span>
              <input type="text" id="newsletterTitle" placeholder="Örn: Haftalık Ekonomi Bülteni: Küresel Piyasalarda Son Durum (Boş bırakılırsa AI başlığı otomatik üretir)" style="width: 100%; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none; box-sizing: border-box;">
            </div>

            <div id="itemsContainer" style="display: flex; flex-direction: column; gap: 16px;">
              
              <!-- Item Slot 1 (Link by default) -->
              <div class="item-row" data-type="url" style="display: flex; gap: 8px; align-items: flex-start; background: #F8F9FA; padding: 12px; border-radius: 8px; border: 1px solid #E2E8F0;">
                <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                  <span class="item-label" style="font-weight: 700; color: #4A5568; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Haber #1 (Link)</span>
                  <input type="url" placeholder="https://example.com/haber-linki" required style="width: 100%; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none;">
                </div>
                <button type="button" class="btn btn-secondary btn-remove-item" disabled style="padding: 10px 16px; margin-top: 18px; background-color: #E2E8F0; color: #718096; border-color: #E2E8F0; cursor: not-allowed; border-radius: 6px;">✕</button>
              </div>

              <!-- Item Slot 2 (Text/Yazı by default) -->
              <div class="item-row" data-type="text" style="display: flex; gap: 8px; align-items: flex-start; background: #F8F9FA; padding: 12px; border-radius: 8px; border: 1px solid #E2E8F0;">
                <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                  <span class="item-label" style="font-weight: 700; color: #4A5568; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Haber #2 (Yazı)</span>
                  <textarea placeholder="Gördüğünüz veya kopyaladığınız haber metnini buraya girin..." rows="3" style="width: 100%; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none; resize: vertical;"></textarea>
                </div>
                <button type="button" class="btn btn-secondary btn-remove-item" style="padding: 10px 16px; margin-top: 18px; border-radius: 6px;">✕</button>
              </div>

            </div>

            <div style="display: flex; gap: 12px; margin-top: 12px; flex-wrap: wrap;">
              <button type="button" id="btnAddLink" class="btn btn-secondary" style="padding: 10px 20px; font-size: 13px; border-radius: 6px; background-color: #EDF2F7; border-color: #CBD5E0; color: #4A5568;">
                ➕ Link Ekle
              </button>
              <button type="button" id="btnAddText" class="btn btn-secondary" style="padding: 10px 20px; font-size: 13px; border-radius: 6px; background-color: #EDF2F7; border-color: #CBD5E0; color: #4A5568;">
                📝 Yazı Ekle
              </button>
              <button type="button" id="btnAddAnalysis" class="btn btn-secondary" style="padding: 10px 20px; font-size: 13px; border-radius: 6px; background-color: #EDF2F7; border-color: #CBD5E0; color: #4A5568;">
                ✍️ Analiz Ekle
              </button>
              <button type="submit" id="btnSubmitNewsletter" class="btn btn-primary" style="flex: 1; min-width: 180px; padding: 12px 24px; font-weight: 600; border-radius: 6px;">
                🤖 AI ile Bülten Derle
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Loading State Panel -->
      <div id="newsletterLoading" class="card" style="display: none; text-align: center; padding: 40px 20px;">
        <div style="font-size: 40px; margin-bottom: 16px; animation: spin 2s linear infinite; display: inline-block;">⚙️</div>
        <h3 style="font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; margin-bottom: 8px; color: #1A1A1A;">Bülteniniz Derleniyor...</h3>
        <p style="color: #718096; font-size: 13px; max-width: 400px; margin: 0 auto 20px auto; line-height: 1.5;">Haber kaynakları okunuyor, resimler kalıcı depolamaya indiriliyor ve kapak kolajı oluşturuluyor. Lütfen bekleyin.</p>
        <div style="width: 100%; height: 6px; background-color: #E2E8F0; border-radius: 3px; overflow: hidden; position: relative;">
          <div style="position: absolute; height: 100%; background-color: #C53030; width: 30%; border-radius: 3px; animation: loadingBar 2s ease-in-out infinite;"></div>
        </div>
      </div>

    </div>
  </main>

  <style>
    @keyframes spin {
      100% { transform: rotate(360deg); }
    }
    @keyframes loadingBar {
      0% { left: -30%; }
      50% { left: 100%; }
      100% { left: 100%; }
    }
  </style>

  <script src="/js/admin.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('itemsContainer');
      const btnAddLink = document.getElementById('btnAddLink');
      const btnAddText = document.getElementById('btnAddText');
      const btnAddAnalysis = document.getElementById('btnAddAnalysis');
      const form = document.getElementById('newsletterForm');
      const loading = document.getElementById('newsletterLoading');
      const cardForm = form.closest('.card');

      // Update slot numbers & delete buttons state
      const updateSlots = () => {
        const rows = container.querySelectorAll('.item-row');
        rows.forEach((row, idx) => {
          const type = row.getAttribute('data-type');
          let typeLabel = 'Link';
          if (type === 'text') typeLabel = 'Yazı';
          if (type === 'analysis') typeLabel = 'Analiz';
          
          let prefix = 'Haber';
          if (type === 'analysis') prefix = 'Analiz';

          row.querySelector('.item-label').textContent = `${prefix} #${idx + 1} (${typeLabel})`;
          
          const removeBtn = row.querySelector('.btn-remove-item');
          if (rows.length === 1) {
            removeBtn.disabled = true;
            removeBtn.style.cursor = 'not-allowed';
            removeBtn.style.backgroundColor = '#E2E8F0';
            removeBtn.style.color = '#718096';
            removeBtn.style.borderColor = '#E2E8F0';
          } else {
            removeBtn.disabled = false;
            removeBtn.style.cursor = 'pointer';
            removeBtn.style.backgroundColor = '';
            removeBtn.style.color = '';
            removeBtn.style.borderColor = '';
          }
        });
      };

      // Add dynamic link input row
      const addLinkRow = () => {
        const rowsCount = container.querySelectorAll('.item-row').length;
        if (rowsCount >= 10) {
          alert('Tek seferde en fazla 10 adet haber ekleyebilirsiniz.');
          return;
        }

        const newRow = document.createElement('div');
        newRow.className = 'item-row';
        newRow.setAttribute('data-type', 'url');
        newRow.style.display = 'flex';
        newRow.style.gap = '8px';
        newRow.style.alignItems = 'flex-start';
        newRow.style.background = '#F8F9FA';
        newRow.style.padding = '12px';
        newRow.style.borderRadius = '8px';
        newRow.style.border = '1px solid #E2E8F0';

        newRow.innerHTML = `
          <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
            <span class="item-label" style="font-weight: 700; color: #4A5568; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Haber (Link)</span>
            <input type="url" placeholder="https://example.com/haber-linki" required style="width: 100%; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none;">
          </div>
          <button type="button" class="btn btn-secondary btn-remove-item" style="padding: 10px 16px; margin-top: 18px; border-radius: 6px;">✕</button>
        `;
        container.appendChild(newRow);
        
        // Bind delete
        newRow.querySelector('.btn-remove-item').addEventListener('click', () => {
          newRow.remove();
          updateSlots();
        });

        updateSlots();
      };

      // Add dynamic text input row
      const addTextRow = () => {
        const rowsCount = container.querySelectorAll('.item-row').length;
        if (rowsCount >= 10) {
          alert('Tek seferde en fazla 10 adet haber ekleyebilirsiniz.');
          return;
        }

        const newRow = document.createElement('div');
        newRow.className = 'item-row';
        newRow.setAttribute('data-type', 'text');
        newRow.style.display = 'flex';
        newRow.style.gap = '8px';
        newRow.style.alignItems = 'flex-start';
        newRow.style.background = '#F8F9FA';
        newRow.style.padding = '12px';
        newRow.style.borderRadius = '8px';
        newRow.style.border = '1px solid #E2E8F0';

        newRow.innerHTML = `
          <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
            <span class="item-label" style="font-weight: 700; color: #4A5568; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Haber (Yazı)</span>
            <textarea placeholder="Gördüğünüz veya kopyaladığınız haber metnini buraya girin..." rows="3" required style="width: 100%; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none; resize: vertical;"></textarea>
          </div>
          <button type="button" class="btn btn-secondary btn-remove-item" style="padding: 10px 16px; margin-top: 18px; border-radius: 6px;">✕</button>
        `;
        container.appendChild(newRow);
        
        // Bind delete
        newRow.querySelector('.btn-remove-item').addEventListener('click', () => {
          newRow.remove();
          updateSlots();
        });

        updateSlots();
      };

      // Add dynamic analysis input row
      const addAnalysisRow = () => {
        const rowsCount = container.querySelectorAll('.item-row').length;
        if (rowsCount >= 10) {
          alert('Tek seferde en fazla 10 adet haber ekleyebilirsiniz.');
          return;
        }

        const newRow = document.createElement('div');
        newRow.className = 'item-row';
        newRow.setAttribute('data-type', 'analysis');
        newRow.style.display = 'flex';
        newRow.style.gap = '8px';
        newRow.style.alignItems = 'flex-start';
        newRow.style.background = '#F8F9FA';
        newRow.style.padding = '12px';
        newRow.style.borderRadius = '8px';
        newRow.style.border = '1px solid #E2E8F0';

        newRow.innerHTML = `
          <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
            <span class="item-label" style="font-weight: 700; color: #4A5568; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Analiz (Yazı)</span>
            <textarea placeholder="Kendi analizinizi veya yorumunuzu buraya girin..." rows="3" required style="width: 100%; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none; resize: vertical;"></textarea>
          </div>
          <button type="button" class="btn btn-secondary btn-remove-item" style="padding: 10px 16px; margin-top: 18px; border-radius: 6px;">✕</button>
        `;
        container.appendChild(newRow);
        
        // Bind delete
        newRow.querySelector('.btn-remove-item').addEventListener('click', () => {
          newRow.remove();
          updateSlots();
        });

        updateSlots();
      };

      // Bind button events
      btnAddLink.addEventListener('click', addLinkRow);
      btnAddText.addEventListener('click', addTextRow);
      btnAddAnalysis.addEventListener('click', addAnalysisRow);

      // Bind initial delete buttons
      container.querySelectorAll('.btn-remove-item').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.target.closest('.item-row').remove();
          updateSlots();
        });
      });

      // Form submission
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const rows = Array.from(container.querySelectorAll('.item-row'));
        const items = rows.map(row => {
          const type = row.getAttribute('data-type');
          const valueInput = type === 'url' ? row.querySelector('input') : row.querySelector('textarea');
          return {
            type,
            value: valueInput.value.trim()
          };
        }).filter(item => item.value.length > 0);

        if (items.length === 0) {
          alert('Lütfen en az bir haber linki veya yazısı girin.');
          return;
        }

        const titleVal = document.getElementById('newsletterTitle').value.trim();

        // Show loading state
        cardForm.style.display = 'none';
        loading.style.display = 'block';

        try {
          const response = await fetch('/api/ai/process-newsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              items,
              title: titleVal || undefined
            })
          });

          const res = await response.json();
          if (!response.ok || !res.success) {
            throw new Error(res.message || 'Bülten derleme hatası.');
          }

          // Write compiled bülten data to sessionStorage for editor form consumption
          sessionStorage.setItem('newsletter_data', JSON.stringify({
            title: res.data.title,
            excerpt: res.data.excerpt,
            content: res.data.content,
            category: res.data.category,
            tags: res.data.tags,
            cover_image: res.data.cover_image,
            resolvedImages: res.resolvedImages
          }));

          // Redirect to New Article Editor
          window.location.href = '/admin/haberler/yeni';

        } catch (err) {
          alert(`Hata: ${err.message}`);
          cardForm.style.display = 'block';
          loading.style.display = 'none';
        }
      });

    });
  </script>

</body>
</html>
