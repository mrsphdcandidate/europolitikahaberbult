<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (typeof article !== 'undefined' && article) ? 'Haberi Düzenle' : 'Yeni Haber' %> — EuroPolitika Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" aria-label="Menüyü aç">☰</button>
  <div class="sidebar-overlay"></div>

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <a href="/admin" class="sidebar-logo">EURO<span>POLITIKA</span></a>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-item">
        <span class="nav-icon">📊</span> Dashboard
      </a>
      <a href="/admin/haberler" class="nav-item active">
        <span class="nav-icon">📰</span> Haberler
      </a>
      <a href="/admin/bulten-olustur" class="nav-item">
        <span class="nav-icon">✉️</span> Bülten Oluştur
      </a>
      <a href="/admin/aboneler" class="nav-item">
        <span class="nav-icon">👥</span> Aboneler
      </a>
      <a href="/" class="nav-item" target="_blank">
        <span class="nav-icon">🌐</span> Siteye Git
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="nav-item logout">
        <span class="nav-icon">🚪</span> Çıkış
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1><%= (typeof article !== 'undefined' && article) ? 'Haberi Düzenle' : 'Yeni Haber' %></h1>
      <div class="topbar-actions">
        <a href="/admin/haberler" class="btn btn-secondary">← Geri Dön</a>
      </div>
    </div>

    <div class="admin-content">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <span>⚠️</span> <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/haberler" class="editor-form">
        <% if (typeof article !== 'undefined' && article && (article._id || article.id)) { %>
          <input type="hidden" name="id" value="<%= article._id || article.id %>">
        <% } %>

        <div class="editor-grid">

          <!-- Left Column: Main Editor -->
          <div class="editor-main">

            <!-- AI Processing Section (only for new articles) -->
            <% if (typeof article === 'undefined' || !article) { %>
              <div class="ai-section">
                <div class="ai-section-title">
                  🤖 AI ile Haberleştir
                </div>
                <p class="ai-section-desc">
                  Ham içeriği yapıştırın, AI otomatik olarak başlık, özet ve içerik oluşturacak.
                </p>

                <div class="form-group">
                  <textarea
                    id="rawContent"
                    rows="8"
                    placeholder="Ham içeriğinizi buraya yapıştırın... (haber linki, metin veya notlar)"
                  ></textarea>
                </div>

                <div class="ai-actions">
                  <button type="button" id="aiProcessBtn" class="btn btn-primary btn-lg">
                    🤖 AI ile Haberleştir
                  </button>
                </div>

                <!-- Loading Indicator -->
                <div class="ai-loading">
                  <div class="ai-spinner"></div>
                  <span class="ai-loading-text">İçerik işleniyor<span>...</span></span>
                </div>

                <!-- Success Message -->
                <div class="ai-result">
                  ✅ İçerik başarıyla işlendi! Alanları kontrol edin ve yayınlayın.
                </div>
              </div>
            <% } %>

            <!-- Editor Fields -->
            <div class="editor-fields" style="<%= (typeof article === 'undefined' || !article) ? 'display:none;' : '' %>">
              <div class="card">
                <div class="card-body">
                  <div class="form-group">
                    <label for="title">Başlık</label>
                    <input
                      type="text"
                      id="title"
                      name="title"
                      placeholder="Haber başlığını girin"
                      value="<%= (typeof article !== 'undefined' && article && article.title) ? article.title : '' %>"
                      required
                    >
                  </div>

                  <div class="form-group">
                    <label for="excerpt">Özet</label>
                    <textarea
                      id="excerpt"
                      name="excerpt"
                      rows="3"
                      placeholder="Kısa özet yazın (ana sayfada görünecek)"
                    ><%= (typeof article !== 'undefined' && article && article.excerpt) ? article.excerpt : '' %></textarea>
                  </div>

                  <div class="form-group">
                    <label for="content">İçerik</label>
                    <textarea
                      id="content"
                      name="content"
                      rows="15"
                      placeholder="Haber içeriğini yazın (HTML desteklenir)"
                      required
                    ><%= (typeof article !== 'undefined' && article && article.content) ? article.content : '' %></textarea>
                  </div>

                  <div class="form-group" style="margin-top: 1.5rem; border-top: 1px solid #E2E8F0; padding-top: 1.5rem;">
                    <label for="editor_analysis" style="display: flex; align-items: center; gap: 6px;">
                      <span style="font-weight: 700; color: #1A1A1A;">⭐ Editör Özel Analizi / Yorumu (Opsiyonel)</span>
                      <span style="font-size: 10px; font-weight: 700; color: #C53030; background: #FFF5F5; border: 1px solid #FED7D7; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px;">Dış Analiz Kutusu</span>
                    </label>
                    <textarea
                      id="editor_analysis"
                      name="editor_analysis"
                      rows="6"
                      placeholder="Dışarıda başka bir yapay zekaya (ChatGPT, Claude vb.) yaptırdığınız kendi analiz veya yorumlarınızı buraya yapıştırabilirsiniz. Bu alan bültenin en altında ayrı şık bir kutu halinde görünecektir."
                      style="width: 100%; border: 1px solid #CBD5E0; border-radius: 6px; padding: 12px; font-family: inherit; font-size: 14px; line-height: 1.5; resize: vertical; box-sizing: border-box;"
                    ><%= (typeof article !== 'undefined' && article && article.editor_analysis) ? article.editor_analysis : '' %></textarea>
                  </div>

                  <div class="form-group" style="margin-top: 1.5rem; border-top: 1px solid #E2E8F0; padding-top: 1.5rem;">
                    <label for="key_takeaways" style="display: flex; align-items: center; gap: 6px;">
                      <span style="font-weight: 700; color: #1A1A1A;">💡 3 Maddede Öne Çıkanlar (Opsiyonel)</span>
                      <span style="font-size: 10px; font-weight: 700; color: #3182CE; background: #EBF8FF; border: 1px solid #BEE3F8; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px;">Özet Maddeleri</span>
                    </label>
                    <textarea
                      id="key_takeaways"
                      name="key_takeaways"
                      rows="4"
                      placeholder="Her satıra tek bir madde gelecek şekilde yazın (maksimum 3 satır/madde).&#10;Örn:&#10;Rusya, Finlandiya sınırındaki demiryolu geçişlerini askıya aldı.&#10;İrlanda altı ay boyunca AB dönem başkanlığını devraldı.&#10;Hyatt İtalya'daki lüks otel portföyünü genişletti."
                      style="width: 100%; border: 1px solid #CBD5E0; border-radius: 6px; padding: 12px; font-family: inherit; font-size: 14px; line-height: 1.5; resize: vertical; box-sizing: border-box;"
                    ><%= (typeof article !== 'undefined' && article && article.key_takeaways) ? article.key_takeaways : '' %></textarea>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <!-- Right Column: Settings Sidebar -->
          <div class="editor-sidebar">

            <!-- Cover Image -->
            <div class="card">
              <div class="card-header">
                <h2>Kapak Görseli</h2>
              </div>
              <div class="card-body">
                <div class="image-upload-area">
                  <input type="file" id="coverImageInput" accept="image/*">
                  <div class="upload-icon">📷</div>
                  <div class="upload-text">Görsel yüklemek için tıklayın</div>
                  <div class="upload-hint">JPEG, PNG, WebP — Max 5MB</div>
                </div>

                <div class="image-preview <%= (typeof article !== 'undefined' && article && article.cover_image) ? 'visible' : '' %>">
                  <% if (typeof article !== 'undefined' && article && article.cover_image) { %>
                    <img src="<%= article.cover_image %>" alt="Kapak görseli">
                  <% } %>
                </div>

                <div class="url-upload-area" style="margin-top: 12px; border-top: 1px solid #E2E8F0; padding-top: 12px;">
                  <label for="coverImageUrlInput" style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: #718096; display: block; margin-bottom: 6px;">Veya URL'den Görsel Çek</label>
                  <div style="display: flex; gap: 6px;">
                    <input type="text" id="coverImageUrlInput" placeholder="http://...jpg" style="flex: 1; padding: 6px 10px; border: 1px solid #CBD5E0; border-radius: 4px; font-size: 13px; font-family: inherit;">
                    <button type="button" id="btnDownloadCoverUrl" class="btn btn-secondary btn-sm" style="padding: 6px 12px; font-size: 12px;">İndir</button>
                  </div>
                </div>

                <input
                  type="hidden"
                  id="coverImage"
                  name="cover_image"
                  value="<%= (typeof article !== 'undefined' && article && article.cover_image) ? article.cover_image : '' %>"
                >
              </div>
            </div>

            <!-- Inline Images Card -->
            <div class="card" id="inlineImagesCard" style="display: none; margin-top: 15px;">
              <div class="card-header">
                <h2>Haber İçi Görseller</h2>
              </div>
              <div class="card-body" id="inlineImagesContainer" style="display: flex; flex-direction: column; gap: 16px;">
                <!-- Dynamically populated via javascript -->
              </div>
            </div>

            <!-- Category -->
            <div class="card">
              <div class="card-header">
                <h2>Ayarlar</h2>
              </div>
              <div class="card-body">
                <div class="form-group">
                  <label for="category">Kategori</label>
                  <select id="category" name="category">
                    <option value="">Kategori seçin</option>
                    <% const categories = ['Makroekonomi', 'Türkiye Ekonomisi', 'Küresel Politika', 'Merkez Bankaları', 'Piyasalar', 'Analiz']; %>
                    <% categories.forEach(function(cat) { %>
                      <option
                        value="<%= cat %>"
                        <%= (typeof article !== 'undefined' && article && article.category === cat) ? 'selected' : '' %>
                      >
                        <%= cat %>
                      </option>
                    <% }); %>
                  </select>
                </div>

                <div class="form-group">
                  <label for="tags">Etiketler</label>
                  <input
                    type="text"
                    id="tags"
                    name="tags"
                    placeholder="Virgülle ayırarak yazın"
                    value="<%= (typeof article !== 'undefined' && article && article.tags) ? (Array.isArray(article.tags) ? article.tags.join(', ') : article.tags) : '' %>"
                  >
                  <p class="form-hint">Örn: ekonomi, faiz, enflasyon</p>
                </div>

                <div class="form-group">
                  <label for="status">Durum</label>
                  <select id="status" name="status">
                    <option
                      value="draft"
                      <%= (typeof article !== 'undefined' && article && article.status === 'draft') ? 'selected' : '' %>
                    >
                      Taslak
                    </option>
                    <option
                      value="published"
                      <%= (typeof article !== 'undefined' && article && article.status === 'published') ? 'selected' : '' %>
                    >
                      Yayında
                    </option>
                  </select>
                </div>
              </div>
            </div>

            <% if (typeof article !== 'undefined' && article) { %>
              <!-- Sosyal Medya Paylaşım Yardımcısı -->
              <div class="card" style="margin-top: 15px;">
                <div class="card-header" style="background: #1A1A1A; color: #FFFFFF;">
                  <h2 style="color: #FFFFFF; font-size: 14px; display: flex; align-items: center; gap: 6px;">📱 Sosyal Medya Yardımcısı</h2>
                </div>
                <div class="card-body" style="padding: 15px; font-family: 'Inter', sans-serif;">
                  <p style="font-size: 12px; color: #718096; margin-bottom: 12px; line-height: 1.4;">Yazı yayındayken sosyal mecralarda hızlıca paylaşmanız için hazır yapay zeka taslakları:</p>
                  
                  <!-- X / Twitter -->
                  <div style="margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                      <span style="font-size: 11px; font-weight: 700; color: #1A1A1A; text-transform: uppercase;">𝕏 / Twitter</span>
                      <button type="button" class="btn-copy-social" data-target="socialTextX" style="background: none; border: none; color: #C53030; font-size: 11px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 4px; padding: 0;">📋 Kopyala</button>
                    </div>
                    <% 
                      let xText = `📰 ${article.title}\n\n`;
                      if (article.key_takeaways) {
                        xText += article.key_takeaways.split('\n').map(l => `• ${l.trim()}`).filter(l => l.length > 2).join('\n') + '\n\n';
                      } else if (article.excerpt) {
                        xText += `${article.excerpt}\n\n`;
                      }
                      xText += `Detaylı analiz için okuyun:\n🔗 https://europolitika.up.railway.app/haber/${article.slug}\n\n#politik #ekonomi #yatirim`;
                    %>
                    <textarea id="socialTextX" readonly style="width: 100%; height: 110px; font-size: 12px; border: 1px solid #E2E8F0; border-radius: 4px; padding: 8px; background: #F8F9FA; resize: none; font-family: inherit; color: #4A5568; box-sizing: border-box;"><%= xText %></textarea>
                  </div>

                  <!-- LinkedIn -->
                  <div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                      <span style="font-size: 11px; font-weight: 700; color: #1A1A1A; text-transform: uppercase;">💼 LinkedIn</span>
                      <button type="button" class="btn-copy-social" data-target="socialTextLI" style="background: none; border: none; color: #C53030; font-size: 11px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 4px; padding: 0;">📋 Kopyala</button>
                    </div>
                    <% 
                      let liText = `📊 EuroPolitika Özel Analizi: ${article.title}\n\n`;
                      if (article.excerpt) {
                        liText += `${article.excerpt}\n\n`;
                      }
                      if (article.key_takeaways) {
                        liText += `🔍 Öne Çıkan Başlıklar:\n` + article.key_takeaways.split('\n').map(l => `- ${l.trim()}`).filter(l => l.length > 2).join('\n') + '\n\n';
                      }
                      liText += `Makalenin tamamı ve derinlemesine politik ekonomi değerlendirmesi web sitemizde yayınlandı:\n🔗 https://europolitika.up.railway.app/haber/${article.slug}\n\n#politikekonomi #yatirim #makroekonomi #merkezbankasi`;
                    %>
                    <textarea id="socialTextLI" readonly style="width: 100%; height: 130px; font-size: 12px; border: 1px solid #E2E8F0; border-radius: 4px; padding: 8px; background: #F8F9FA; resize: none; font-family: inherit; color: #4A5568; box-sizing: border-box;"><%= liText %></textarea>
                  </div>

                  <!-- Social Sharing Image -->
                  <% if (article.social_image) { %>
                    <div style="margin-top: 15px; border-top: 1px solid #E2E8F0; padding-top: 15px; text-align: center;">
                      <span style="font-size: 11px; font-weight: 700; color: #718096; text-transform: uppercase; display: block; margin-bottom: 8px;">Sosyal Paylaşım Görseli</span>
                      <a href="<%= article.social_image %>" download="<%= article.slug %>-sosyal.png" class="btn btn-secondary btn-sm" style="display: inline-flex; align-items: center; gap: 6px; width: 100%; justify-content: center; font-size: 12px;">📥 Görseli İndir</a>
                    </div>
                  <% } %>
                </div>
              </div>
            <% } %>

            <!-- Actions -->
            <div class="card">
              <div class="card-body">
                <button type="button" id="btnSubmitEditor" class="btn btn-primary btn-full btn-lg">
                  <%= (typeof article !== 'undefined' && article) ? '💾 Güncelle' : '🚀 Yayınla' %>
                </button>
                <% if (typeof article !== 'undefined' && article) { %>
                  <a
                    href="/admin/haberler"
                    class="btn btn-secondary btn-full mt-2"
                    style="margin-top: 0.75rem;"
                  >
                    İptal
                  </a>
                <% } %>
              </div>
            </div>

        <input type="hidden" id="socialImage" name="social_image" value="<%= (typeof article !== 'undefined' && article && article.social_image) ? article.social_image : '' %>">
      </form>

    </div>
  </main>

  <!-- Hidden container for generating shareable social image card in editor -->
  <div id="shareCardTemplate" style="position: absolute; left: -9999px; top: -9999px; width: 600px; background-color: #F8F7F4; padding: 40px; box-sizing: border-box; border: 4px solid #C53030; border-radius: 12px; font-family: 'Inter', sans-serif;">
    <div style="text-align: center; border-bottom: 2px solid #E8E4DE; padding-bottom: 15px; margin-bottom: 25px;">
      <span style="font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 900; letter-spacing: 2px; color: #1A1A1A;">EURO<span style="color: #C53030;">POLITIKA</span></span>
      <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 3px; color: #718096; margin-top: 4px;">Politik Ekonomi Bülteni</div>
    </div>
    
    <div class="card-category" style="font-size: 12px; font-weight: 700; color: #C53030; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 10px;">Genel</div>
    <h1 class="card-title" style="font-family: 'Playfair Display', serif; font-size: 28px; line-height: 1.35; color: #1A1A1A; margin-bottom: 20px; font-weight: 800;">Haber Başlığı</h1>
    
    <div class="card-cover-container" style="width: 100%; height: 300px; border-radius: 8px; overflow: hidden; margin-bottom: 25px; border: 1px solid #E8E4DE; display: none;">
      <img class="card-cover-img" src="" style="width: 100%; height: 100%; object-fit: cover;">
    </div>
    
    <div class="card-excerpt" style="font-size: 15px; line-height: 1.6; color: #333; margin-bottom: 30px; font-weight: 400;"></div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #E8E4DE; padding-top: 20px;">
      <div class="card-date" style="font-size: 12px; color: #718096;"></div>
      <div style="font-size: 13px; font-weight: 600; color: #1A1A1A;">europolitika.up.railway.app</div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
