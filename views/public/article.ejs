  <article class="article-detail">
  <!-- Cover Image -->
  <div class="article-cover">
    <div class="article-cover-image">
      <% if (article.cover_image) { %>
        <img src="<%= article.cover_image %>" alt="<%= article.title %>" loading="eager">
      <% } else { %>
        <div class="article-cover-placeholder"></div>
      <% } %>
    </div>
  </div>

  <!-- Article Header -->
  <div class="article-header">
    <div class="article-meta-top">
      <% if (article.category) { %>
        <span class="category-pill"><%= article.category %></span>
      <% } %>
      <span class="article-meta-item"><%= formatDate(article.published_at || article.created_at) %></span>
      <% if (typeof article.views !== 'undefined') { %>
        <span class="article-meta-item"><%= article.views %> görüntülenme</span>
      <% } %>
      <span class="article-meta-item"><%= readingTime(article.content) %></span>
    </div>
    <h1 class="article-detail-title"><%= article.title %></h1>
  </div>

  <!-- Article Content -->
  <div class="article-content">
    <%- article.content %>
  </div>

  <!-- Editor Special Analysis Box -->
  <% if (article.editor_analysis) { %>
    <div class="editor-analysis-box" style="margin-top: 40px; padding: 28px; background-color: #FDFBF7; border-left: 4px solid #C53030; border-radius: 4px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border-top: 1px solid #F0ECE4; border-right: 1px solid #F0ECE4; border-bottom: 1px solid #F0ECE4; font-family: 'Inter', sans-serif;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
        <span style="font-size: 16px;">⭐</span>
        <span style="font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 800; color: #1A1A1A; letter-spacing: 0.5px;">EuroPolitika Editör Yorumu & Özel Analizi</span>
      </div>
      <div style="font-size: 15px; line-height: 1.7; color: #2D3748; white-space: pre-wrap;"><%= article.editor_analysis %></div>
    </div>
  <% } %>

  <!-- Premium System CTA / Advertisement Banner -->
  <div class="newsletter-cta-banner" style="background: linear-gradient(135deg, #1A1A1A 0%, #2D3748 100%); color: #FFFFFF; padding: 32px; border-radius: 12px; margin-top: 48px; border: 1px solid #C53030; box-shadow: 0 10px 30px rgba(197, 48, 48, 0.15); font-family: 'Inter', sans-serif; position: relative; overflow: hidden; text-align: left;">
