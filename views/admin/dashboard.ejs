<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — EuroPolitika Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" aria-label="Menüyü aç">☰</button>
  <div class="sidebar-overlay"></div>

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <a href="/admin" class="sidebar-logo">
        <svg class="sidebar-logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 240 40" height="28" width="168">
          <g class="logo-badge" transform="translate(0, 0)">
            <circle cx="20" cy="20" r="18" fill="#003399" />
            <g fill="#FFCC00" transform="translate(20, 20) scale(0.8)">
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(0, -11) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(5.5, -9.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(9.5, -5.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(11, 0) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(9.5, 5.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(5.5, 9.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(0, 11) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(-5.5, 9.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(-9.5, 5.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(-11, 0) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(-9.5, -5.5) scale(0.6)" />
              <path d="M 0,-6 L 1.76,-1.76 L 6.35,-1.76 L 2.63,0.95 L 4.05,5.24 L 0,2.6 L -4.05,5.24 L -2.63,0.95 L -6.35,-1.76 L -1.76,-1.76 Z" transform="translate(-5.5, -9.5) scale(0.6)" />
            </g>
          </g>
          <text x="46" y="29" font-family="'Inter', -apple-system, sans-serif" font-size="24" font-weight="800" fill="var(--logo-text-euro, #003399)" letter-spacing="-0.5">EURO</text>
          <text x="114" y="29" font-family="'Inter', -apple-system, sans-serif" font-size="24" font-weight="400" fill="var(--logo-text-politika, #1A365D)">Politika</text>
        </svg>
      </a>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-item active">
        <span class="nav-icon">📊</span> Dashboard
      </a>
      <a href="/admin/haberler" class="nav-item">
        <span class="nav-icon">📰</span> Haberler
      </a>
      <a href="/admin/bulten-olustur" class="nav-item">
        <span class="nav-icon">✉️</span> Bülten Oluştur
      </a>
      <a href="/admin/aboneler" class="nav-item">
        <span class="nav-icon">👥</span> Aboneler
      </a>
      <a href="/" class="nav-item" target="_blank">
        <span class="nav-icon">🌐</span> Siteye Git
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="nav-item logout">
        <span class="nav-icon">🚪</span> Çıkış
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>Dashboard</h1>
    </div>

    <div class="admin-content">

      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon red">📄</div>
          <div class="stat-info">
            <div class="stat-number"><%= typeof stats !== 'undefined' && stats.totalArticles != null ? stats.totalArticles : 0 %></div>
            <div class="stat-label">Toplam Haber</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon green">✅</div>
          <div class="stat-info">
            <div class="stat-number"><%= typeof stats !== 'undefined' && stats.publishedArticles != null ? stats.publishedArticles : 0 %></div>
            <div class="stat-label">Yayınlanan</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon blue">👥</div>
          <div class="stat-info">
            <div class="stat-number"><%= typeof stats !== 'undefined' && stats.totalSubscribers != null ? stats.totalSubscribers : 0 %></div>
            <div class="stat-label">Abone</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon yellow">👁️</div>
          <div class="stat-info">
            <div class="stat-number"><%= typeof stats !== 'undefined' && stats.totalViews != null ? stats.totalViews : 0 %></div>
            <div class="stat-label">Toplam Görüntülenme</div>
          </div>
        </div>
      </div>

      <!-- Chart and Quick Actions Grid -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
        <div class="card" style="margin-bottom: 0;">
          <div class="card-header">
            <h2>En Çok Okunan Haberler</h2>
          </div>
          <div class="card-body" style="padding: 1.25rem;">
            <canvas id="viewsChart" style="max-height: 200px; width: 100%;"></canvas>
          </div>
        </div>

        <div class="card" style="margin-bottom: 0;">
          <div class="card-header">
            <h2>Hızlı İşlemler</h2>
          </div>
          <div class="card-body" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; padding: 1.25rem;">
            <a href="/admin/haberler/yeni" class="btn btn-primary" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 15px 10px; font-weight: 600; text-align: center; border-radius: 8px; font-size: 13px; text-decoration: none;">
              <span style="font-size: 20px;">✍️</span>
              Yeni Haber Yaz
            </a>
            <a href="/admin/bulten-olustur" class="btn btn-primary" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 15px 10px; font-weight: 600; text-align: center; border-radius: 8px; font-size: 13px; text-decoration: none; background-color: #9B2C2C; border-color: #9B2C2C;">
              <span style="font-size: 20px;">✉️</span>
              Bülten Oluştur
            </a>
            <a href="/admin/haberler" class="btn btn-secondary" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 15px 10px; font-weight: 600; text-align: center; border-radius: 8px; font-size: 13px; text-decoration: none; background-color: #2D3748; color: #fff; border-color: #2D3748;">
              <span style="font-size: 20px;">📰</span>
              Tüm Haberler
            </a>
            <a href="/admin/aboneler" class="btn btn-secondary" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 15px 10px; font-weight: 600; text-align: center; border-radius: 8px; font-size: 13px; text-decoration: none; background-color: #4A5568; color: #fff; border-color: #4A5568;">
              <span style="font-size: 20px;">👥</span>
              Aboneleri Yönet
            </a>
            <a href="/" target="_blank" class="btn btn-secondary" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 15px 10px; font-weight: 600; text-align: center; border-radius: 8px; font-size: 13px; text-decoration: none; background-color: #718096; color: #fff; border-color: #718096;">
              <span style="font-size: 20px;">🌐</span>
              Sitenizi Aç
            </a>
            <a href="/admin/logout" class="btn btn-secondary" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 15px 10px; font-weight: 600; text-align: center; border-radius: 8px; font-size: 13px; text-decoration: none; background-color: #A0AEC0; color: #fff; border-color: #A0AEC0;">
              <span style="font-size: 20px;">🚪</span>
              Güvenli Çıkış
            </a>
          </div>
        </div>
      </div>

      <!-- Recent Articles -->
      <div class="card">
        <div class="card-header">
          <h2>Son Haberler</h2>
          <a href="/admin/haberler" class="btn btn-secondary btn-sm">Tümünü Gör</a>
        </div>
        <div class="table-container">
          <% if (typeof articles !== 'undefined' && articles && articles.length > 0) { %>
            <table>
              <thead>
                <tr>
                  <th>Başlık</th>
                  <th>Kategori</th>
                  <th>Durum</th>
                  <th>Okunma</th>
                  <th>Tarih</th>
                </tr>
              </thead>
              <tbody>
                <% articles.forEach(function(art) { %>
                  <tr>
                    <td>
                      <a href="/admin/haberler/duzenle/<%= art.id %>" class="article-edit-link">
                        <%= art.title %>
                      </a>
                    </td>
                    <td><span class="category-badge"><%= art.category %></span></td>
                    <td>
                      <span class="status-badge <%= art.status === 'published' ? 'published' : 'draft' %>">
                        <%= art.status === 'published' ? 'Yayında' : 'Taslak' %>
                      </span>
                    </td>
                    <td><strong><%= art.views %></strong></td>
                    <td class="date-col">
                      <%= new Date(art.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' }) %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">📰</div>
              <h3>Henüz haber yok</h3>
              <p>İlk haberinizi oluşturmaya başlayın.</p>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const ctx = document.getElementById('viewsChart').getContext('2d');
      
      const articlesData = <%- JSON.stringify(articles || []) %>;
      // Filter out articles with views > 0 or just show what's there
      const topArticles = articlesData
        .sort((a, b) => b.views - a.views)
        .slice(0, 5);

      const labels = topArticles.map(a => a.title.length > 25 ? a.title.substring(0, 22) + '...' : a.title);
      const data = topArticles.map(a => a.views);

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels.length > 0 ? labels : ['Haber Yok'],
          datasets: [{
            label: 'Okunma',
            data: data.length > 0 ? data : [0],
            backgroundColor: '#C53030',
            borderColor: '#C53030',
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            x: { beginAtZero: true, grid: { display: false } },
            y: { grid: { display: false } }
          }
        }
      });
    });
  </script>
  <script src="/js/admin.js"></script>
</body>
</html>
