<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Haberler — EuroPolitika Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" aria-label="Menüyü aç">☰</button>
  <div class="sidebar-overlay"></div>

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <a href="/admin" class="sidebar-logo"><img src="/img/logo.png" alt="EuroPolitika Logo" style="height: 30px; width: auto; max-height: 100%; object-fit: contain; background: #ffffff; padding: 4px; border-radius: 4px;"></a>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-item">
        <span class="nav-icon">📊</span> Dashboard
      </a>
      <a href="/admin/haberler" class="nav-item active">
        <span class="nav-icon">📰</span> Haberler
      </a>
      <a href="/admin/bulten-olustur" class="nav-item">
        <span class="nav-icon">✉️</span> Bülten Oluştur
      </a>
      <a href="/admin/aboneler" class="nav-item">
        <span class="nav-icon">👥</span> Aboneler
      </a>
      <a href="/" class="nav-item" target="_blank">
        <span class="nav-icon">🌐</span> Siteye Git
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="nav-item logout">
        <span class="nav-icon">🚪</span> Çıkış
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>Haberler</h1>
      <div class="topbar-actions">
        <a href="/admin/haberler/yeni" class="btn btn-primary">
          ✏️ Yeni Haber
        </a>
      </div>
    </div>

    <div class="admin-content">

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
          <span>✅</span> <%= success %>
        </div>
      <% } %>

      <div class="card">
        <div class="table-container">
          <% if (typeof articles !== 'undefined' && articles && articles.length > 0) { %>
            <table>
              <thead>
                <tr>
                  <th>Başlık</th>
                  <th>Kategori</th>
                  <th>Durum</th>
                  <th>Tarih</th>
                  <th>İşlemler</th>
                </tr>
              </thead>
              <tbody>
                <% articles.forEach(function(article) { %>
                  <tr>
                    <td>
                      <div class="table-title">
                        <a href="/admin/haberler/<%= article._id || article.id %>/duzenle">
                          <%= article.title %>
                        </a>
                      </div>
                      <% if (article.excerpt) { %>
                        <div class="table-subtitle"><%= article.excerpt.substring(0, 80) %>...</div>
                      <% } %>
                    </td>
                    <td><%= article.category || '—' %></td>
                    <td>
                      <% if (article.status === 'published') { %>
                        <span class="badge badge-published">Yayında</span>
                      <% } else { %>
                        <span class="badge badge-draft">Taslak</span>
                      <% } %>
                    </td>
                    <td class="text-muted text-sm">
                      <%= article.createdAt ? new Date(article.createdAt).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) : '—' %>
                    </td>
                    <td>
                      <div class="table-actions">
                        <a
                          href="/admin/haberler/<%= article._id || article.id %>/duzenle"
                          class="btn btn-secondary btn-sm"
                          title="Düzenle"
                        >
                          ✏️ Düzenle
                        </a>
                        <button
                          class="btn btn-danger btn-sm"
                          data-delete-id="<%= article._id || article.id %>"
                          data-delete-title="<%= article.title %>"
                          title="Sil"
                        >
                          🗑️ Sil
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">📝</div>
              <h3>Henüz haber eklenmemiş</h3>
              <p>İlk haberinizi oluşturmak için aşağıdaki butona tıklayın.</p>
              <a href="/admin/haberler/yeni" class="btn btn-primary">
                ✏️ Yeni Haber Oluştur
              </a>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </main>

  <!-- Delete Confirmation Modal -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal">
      <div class="modal-icon">🗑️</div>
      <h3>Haberi Sil</h3>
      <p>
        "<span class="modal-article-title"></span>" başlıklı haberi silmek istediğinize emin misiniz?
        Bu işlem geri alınamaz.
      </p>
      <div class="modal-actions">
        <button class="btn btn-secondary btn-cancel-delete">İptal</button>
        <button class="btn btn-primary btn-confirm-delete">Evet, Sil</button>
      </div>
    </div>
  </div>

  <script src="/js/admin.js"></script>
</body>
</html>
