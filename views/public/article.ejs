      <h3>ÖNERİLEN ANALİZLER</h3>
      <div class="recommended-list">
        <% if (relatedArticles && relatedArticles.length > 0) { %>
          <% relatedArticles.forEach(function(rel) { %>
            <a href="/haber/<%= rel.slug %>" class="rec-card">
              <% if (rel.cover_image) { %>
                <img src="<%= rel.cover_image %>" alt="<%= rel.title %>">
              <% } else { %>
                <div class="placeholder-img" style="background: linear-gradient(135deg, #1A1A1A 0%, #C53030 100%);"></div>
              <% } %>
              <div class="rec-title"><%= rel.title %></div>
              <div class="rec-meta"><%= formatDate(rel.published_at || rel.created_at) %></div>
            </a>
          <% }); %>
        <% } %>
        <!-- Mock placeholder cards to make layout look rich and full -->
