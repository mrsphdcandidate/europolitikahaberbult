<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Automatically detect if this is a newsletter digest (Bülten)
    const isDigest = '<%= article.category %>' === 'Bülten' || 
                     document.querySelectorAll('.article-content h2, .article-content h3').length >= 2 ||
                     '<%= article.title %>'.toLowerCase().includes('bülten') ||
                     '<%= article.title %>'.toLowerCase().includes('digest');
    
    if (isDigest) {
      // Extract subheadings (excluding image placeholder text)
      const subheadings = Array.from(document.querySelectorAll('.article-content h2, .article-content h3'))
        .map(el => el.textContent.trim())
        .filter(text => text.length > 0 && !text.includes('Görsel Alanı') && !text.includes('Görsel Slotu'));
      
      if (subheadings.length > 0) {
        console.log('[Digest Share Card] Bülten konuları tespit edildi:', subheadings);
        
        // Generate Classic list HTML
        const classicListHtml = `
          <div style="margin-top: 15px; margin-bottom: 25px; text-align: left;">
            <div style="font-size: 11px; font-weight: 700; color: #C53030; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; font-family: 'Inter', sans-serif;">BÜLTEN İÇERİĞİ</div>
            <ul style="margin: 0; padding-left: 20px; list-style-type: square; color: #1A1A1A; font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 600; line-height: 1.5; display: flex; flex-direction: column; gap: 8px;">
              ${subheadings.map(sub => `<li>${sub}</li>`).join('')}
            </ul>
          </div>
        `;

        // Generate Dark list HTML
        const darkListHtml = `
          <div style="margin-top: 15px; margin-bottom: 25px; text-align: left;">
            <div style="font-size: 11px; font-weight: 700; color: #D69E2E; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; font-family: 'Inter', sans-serif;">BÜLTEN İÇERİĞİ</div>
            <ul style="margin: 0; padding-left: 20px; list-style-type: square; color: #FFFFFF; font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 600; line-height: 1.5; display: flex; flex-direction: column; gap: 8px;">
              ${subheadings.map(sub => `<li>${sub}</li>`).join('')}
            </ul>
          </div>
        `;

        // Generate Quote list HTML (centered, clean)
        const quoteListHtml = `
          <div style="margin-top: 15px; margin-bottom: 25px; text-align: center;">
            <div style="font-size: 11px; font-weight: 700; color: #C53030; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 16px; font-family: 'Inter', sans-serif;">BÜLTEN KONULARI</div>
            <ul style="margin: 0; padding: 0; list-style-type: none; color: #1A1A1A; font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; font-style: italic; line-height: 1.6; display: flex; flex-direction: column; gap: 10px; align-items: center;">
              ${subheadings.map(sub => `<li>• ${sub}</li>`).join('')}
            </ul>
          </div>
        `;

        // Generate Tall list HTML
        const tallListHtml = `
          <div style="margin-top: 15px; margin-bottom: 25px; text-align: left;">
            <div style="font-size: 11px; font-weight: 700; color: #C53030; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; font-family: 'Inter', sans-serif;">BÜLTEN İÇERİĞİ</div>
            <ul style="margin: 0; padding-left: 20px; list-style-type: square; color: #1A1A1A; font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 600; line-height: 1.5; display: flex; flex-direction: column; gap: 8px;">
              ${subheadings.map(sub => `<li>${sub}</li>`).join('')}
            </ul>
          </div>
        `;

        // Replace the description blocks in templates
        const classicDesc = document.querySelector('#shareCardTemplate .card-description-block');
        if (classicDesc) classicDesc.innerHTML = classicListHtml;

        const darkDesc = document.querySelector('#shareCardTemplateDark .card-description-block');
        if (darkDesc) darkDesc.innerHTML = darkListHtml;

        const quoteDesc = document.querySelector('#shareCardTemplateQuote .card-description-block');
        if (quoteDesc) quoteDesc.innerHTML = quoteListHtml;

        const tallDesc = document.querySelector('#shareCardTemplateTall .card-description-block');
        if (tallDesc) tallDesc.innerHTML = tallListHtml;
      }
    }

    // Select all trigger buttons (both the inline one and the floating desktop one)
    const triggerButtons = document.querySelectorAll('#btnShareAsImage, .btnShareAsImage');
    const modal = document.getElementById('sharePreviewModal');
    const modalContent = document.getElementById('sharePreviewContent');
    const previewContainer = document.getElementById('sharePreviewImageContainer');
    const btnDownload = document.getElementById('btnDownloadPreview');
    const btnClose = document.getElementById('btnClosePreview');
    
    let currentDataUrl = null;
    let activeTemplate = 'Classic'; // default template

    const renderActiveTemplate = async () => {
      let targetId = 'shareCardTemplate';
      if (activeTemplate === 'Dark') targetId = 'shareCardTemplateDark';
      if (activeTemplate === 'Quote') targetId = 'shareCardTemplateQuote';
      if (activeTemplate === 'Tall') targetId = 'shareCardTemplateTall';
      if (activeTemplate === 'Full') targetId = 'shareCardTemplateFull';
      
      const shareCard = document.getElementById(targetId);
      
      try {
        previewContainer.innerHTML = '<div style="padding: 40px; font-family: Inter; color: #888; font-size: 14px; text-align: center;">⏳ Kart Hazırlanıyor...</div>';
        
        const canvas = await html2canvas(shareCard, {
          allowTaint: true,
          useCORS: true,
          scale: 2,
          backgroundColor: activeTemplate === 'Dark' ? '#121212' : '#F8F7F4'
        });
        
        currentDataUrl = canvas.toDataURL('image/png');
        
        previewContainer.innerHTML = '';
        const img = document.createElement('img');
        img.src = currentDataUrl;
        img.style.maxWidth = '100%';
        img.style.maxHeight = '50vh';
        img.style.objectFit = 'contain';
        img.alt = 'Paylaşım kartı önizleme';
        previewContainer.appendChild(img);
      } catch (error) {
        console.error('Share Image Generation Failed:', error);
        previewContainer.innerHTML = '<div style="padding: 40px; font-family: Inter; color: #C53030; font-size: 14px; text-align: center;">⚠️ Kart oluşturulamadı.</div>';
      }
    };

    // Open Modal and render image
    const openShareModal = async (btn) => {
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '⏳ Hazırlanıyor...';
      
      try {
        // Reset active template to Classic when opening
        activeTemplate = 'Classic';
        updateTabButtonStyles();
        
        // Show Modal immediately
        modal.style.opacity = '1';
        modal.style.visibility = 'visible';
        modalContent.style.transform = 'scale(1)';
        
        await renderActiveTemplate();
        
      } catch (error) {
        console.error('Share Modal error:', error);
        alert('Görsel kartı oluşturulurken bir hata oluştu.');
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    };

    // Bind Tab Click Handlers
    const tabButtons = document.querySelectorAll('.card-tabs .tab-btn');
    
    const updateTabButtonStyles = () => {
      tabButtons.forEach(btn => {
        const templateName = btn.getAttribute('data-template');
        if (templateName === activeTemplate) {
          btn.classList.add('active');
          btn.style.background = '#C53030';
          btn.style.color = '#FFFFFF';
          btn.style.borderColor = '#C53030';
        } else {
          btn.classList.remove('active');
          btn.style.background = 'transparent';
          btn.style.color = '#718096';
          btn.style.borderColor = '#E8E4DE';
        }
      });
    };

    tabButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const templateName = btn.getAttribute('data-template');
        if (templateName === activeTemplate) return;
        
        activeTemplate = templateName;
        updateTabButtonStyles();
        await renderActiveTemplate();
      });
    });

    // Close Modal helper
    const closeShareModal = () => {
      modal.style.opacity = '0';
      modal.style.visibility = 'hidden';
      modalContent.style.transform = 'scale(0.9)';
    };

    // Bind triggers
    triggerButtons.forEach(btn => {
      btn.addEventListener('click', () => openShareModal(btn));
    });

    // Bind close actions
    btnClose.addEventListener('click', closeShareModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeShareModal();
    });

    // Bind download action
    btnDownload.addEventListener('click', () => {
      if (!currentDataUrl) return;
      const link = document.createElement('a');
      link.download = '<%= article.slug %>-paylas.png';
      link.href = currentDataUrl;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      if (window.showToast) {
        window.showToast('Görsel kartı başarıyla indirildi!', 'success');
      }
    });

    // Fetch live market data from backend Yahoo Finance proxy
    async function fetchMarketData() {
      try {
        const response = await fetch('/api/market-data');
        if (!response.ok) return;
        const res = await response.json();
        if (!res.success || !res.data) return;

        const data = res.data;
        Object.keys(data).forEach(symbol => {
          const item = data[symbol];
          const row = document.getElementById(`ticker-${symbol}`);
          if (row) {
            const valEl = row.querySelector('.ticker-value');
            const changeEl = row.querySelector('.ticker-change');
            
            if (valEl && changeEl) {
              // Format value
              let formattedPrice = item.price;
              if (symbol.includes('TRY')) {
                formattedPrice = item.price.toFixed(2) + ' ₺';
              } else if (symbol.includes('USD') || symbol === 'EURUSD=X') {
                formattedPrice = item.price.toFixed(4);
              } else if (symbol.startsWith('^') || symbol.includes('.IS')) {
                formattedPrice = Math.round(item.price).toLocaleString('tr-TR');
              } else {
                formattedPrice = '$' + item.price.toFixed(2);
              }
              valEl.textContent = formattedPrice;

              // Format change percent
              const pct = item.changePercent;
              const sign = pct >= 0 ? '▲' : '▼';
              changeEl.textContent = `${sign} %${Math.abs(pct).toFixed(2)}`;
              
              // Apply classes
              changeEl.className = 'ticker-change ' + (pct >= 0 ? 'positive' : 'negative');
            }
          }
        });
      } catch (error) {
        console.error('Error fetching market data:', error);
      }
    }
    fetchMarketData();
    setInterval(fetchMarketData, 60000); // refresh every minute
  });
</script>

<%- include('../partials/footer') %>
