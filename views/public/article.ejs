<%- include('../partials/header', {
  pageTitle: typeof article !== 'undefined' ? article.title : 'Yazı',
  pageDescription: typeof article !== 'undefined' && article.excerpt ? article.excerpt : '',
  ogType: 'article',
  ogImage: typeof article !== 'undefined' && article.cover_image ? article.cover_image : ''
}) %>

<%
  // Helper: format date in Turkish
  function formatDate(dateStr) {
    if (!dateStr) return '';
    var d = new Date(dateStr);
    var months = ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz', 'Ağustos', 'Eylül', 'Ekim', 'Kasım', 'Aralık'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
  }

  // Helper: estimate reading time (Turkish)
  function readingTime(content) {
    if (!content) return '1 dk';
    var text = content.replace(/<[^>]*>/g, '');
    var words = text.split(/\s+/).length;
    var minutes = Math.max(1, Math.ceil(words / 200));
    return minutes + ' dk okuma';
  }

  // Helper: truncate text
  function truncate(str, len) {
    if (!str) return '';
    if (str.length <= len) return str;
    return str.substring(0, len).trim() + '...';
  }

  var relatedArticles = typeof recentArticles !== 'undefined' ? recentArticles : [];
%>

<!-- Floating Share Bar for Desktop -->
<div class="desktop-share-bar">
  <button class="share-btn twitter" data-platform="twitter" type="button" title="𝕏 Twitter'da Paylaş">𝕏</button>
  <button class="share-btn linkedin" data-platform="linkedin" type="button" title="LinkedIn'de Paylaş">in</button>
  <button class="share-btn whatsapp" data-platform="whatsapp" type="button" title="WhatsApp'ta Paylaş">wa</button>
  <button class="share-btn image-share btnShareAsImage" type="button" title="Görsel Olarak Paylaş">🖼️</button>
</div>

<article class="article-detail">
  <!-- Cover Image -->
  <div class="article-cover">
    <div class="article-cover-image">
      <% if (article.cover_image) { %>
        <img src="<%= article.cover_image %>" alt="<%= article.title %>" loading="eager">
      <% } else { %>
        <div class="article-cover-placeholder"></div>
      <% } %>
    </div>
  </div>

  <!-- Article Header -->
  <div class="article-header">
    <div class="article-meta-top">
      <% if (article.category) { %>
        <span class="category-pill"><%= article.category %></span>
      <% } %>
      <span class="article-meta-item"><%= formatDate(article.published_at || article.created_at) %></span>
      <% if (typeof article.views !== 'undefined') { %>
        <span class="article-meta-item"><%= article.views %> görüntülenme</span>
      <% } %>
      <span class="article-meta-item"><%= readingTime(article.content) %></span>
    </div>
    <h1 class="article-detail-title"><%= article.title %></h1>
  </div>

  <!-- Article Content -->
  <div class="article-content">
    <%- article.content %>
  </div>

  <!-- Share Buttons -->
  <div class="share-section">
    <h3>Bu Yazıyı Paylaş</h3>
    <div class="share-buttons">
      <button class="share-btn twitter" data-platform="twitter" type="button">
        𝕏 Twitter'da Paylaş
      </button>
      <button class="share-btn linkedin" data-platform="linkedin" type="button">
        LinkedIn'de Paylaş
      </button>
      <button class="share-btn whatsapp" data-platform="whatsapp" type="button">
        WhatsApp'ta Paylaş
      </button>
      <button class="share-btn image-share" id="btnShareAsImage" type="button" style="background-color: #C53030; color: white; border-color: #C53030;">
        🖼️ Görsel Olarak Paylaş
      </button>
    </div>
  </div>
</article>

<% if (relatedArticles.length > 0) { %>
<!-- Related Articles -->
<div class="related-section">
  <div class="section-divider">
    <h2>DİĞER YAZILAR</h2>
  </div>
  <div class="related-grid">
    <% relatedArticles.forEach(function(relArticle) { %>
    <article class="article-card">
      <a href="/haber/<%= relArticle.slug %>" class="card-image-wrapper">
        <% if (relArticle.cover_image) { %>
          <img src="<%= relArticle.cover_image %>" alt="<%= relArticle.title %>" loading="lazy">
        <% } else { %>
          <div class="card-image-placeholder"></div>
        <% } %>
      </a>
      <div class="card-body">
        <% if (relArticle.category) { %>
          <span class="card-category"><%= relArticle.category %></span>
        <% } %>
        <h3 class="card-title">
          <a href="/haber/<%= relArticle.slug %>"><%= relArticle.title %></a>
        </h3>
        <% if (relArticle.excerpt) { %>
          <p class="card-excerpt"><%= truncate(relArticle.excerpt, 120) %></p>
        <% } %>
        <div class="card-footer">
          <span class="card-date"><%= formatDate(relArticle.published_at || relArticle.created_at) %></span>
          <a href="/haber/<%= relArticle.slug %>" class="card-read-more">DEVAMINI OKU →</a>
        </div>
      </div>
    </article>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Hidden container for generating shareable image card -->
<div id="shareCardTemplate" style="position: absolute; left: -9999px; top: -9999px; width: 600px; background-color: #F8F7F4; padding: 40px; box-sizing: border-box; border: 4px solid #C53030; border-radius: 12px; font-family: 'Inter', sans-serif;">
  <div style="text-align: center; border-bottom: 2px solid #E8E4DE; padding-bottom: 15px; margin-bottom: 25px;">
    <span style="font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 900; letter-spacing: 2px; color: #1A1A1A;">EURO<span style="color: #C53030;">POLITIKA</span></span>
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 3px; color: #718096; margin-top: 4px;">Politik Ekonomi Bülteni</div>
  </div>
  
  <% if (article.category) { %>
    <div style="font-size: 12px; font-weight: 700; color: #C53030; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 10px;"><%= article.category %></div>
  <% } %>
  
  <h1 style="font-family: 'Playfair Display', serif; font-size: 28px; line-height: 1.35; color: #1A1A1A; margin-bottom: 20px; font-weight: 800;"><%= article.title %></h1>
  
  <% if (article.cover_image) { %>
    <div style="width: 100%; height: 300px; border-radius: 8px; overflow: hidden; margin-bottom: 25px; border: 1px solid #E8E4DE;">
      <img src="<%= article.cover_image %>" style="width: 100%; height: 100%; object-fit: cover;" crossorigin="anonymous">
    </div>
  <% } %>
  
  <div style="font-size: 15px; line-height: 1.6; color: #333; margin-bottom: 30px; font-weight: 400;">
    <%= article.excerpt || (article.content ? truncate(article.content.replace(/<[^>]*>/g, ''), 250) : '') %>
  </div>
  
  <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #E8E4DE; padding-top: 20px;">
    <div style="font-size: 12px; color: #718096;"><%= formatDate(article.published_at || article.created_at) %></div>
    <div style="font-size: 13px; font-weight: 600; color: #1A1A1A;">europolitika.up.railway.app</div>
  </div>
</div>

<!-- Share Preview Modal -->
<div id="sharePreviewModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; z-index: 99999; opacity: 0; visibility: hidden; transition: all 0.3s ease; backdrop-filter: blur(8px);">
  <div style="background: #FFFFFF; border-radius: 12px; max-width: 480px; width: 90%; max-height: 90vh; overflow-y: auto; padding: 24px; box-shadow: 0 15px 40px rgba(0,0,0,0.3); transform: scale(0.9); transition: all 0.3s ease; display: flex; flex-direction: column; align-items: center; box-sizing: border-box;" id="sharePreviewContent">
    <h3 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1A1A1A; margin: 0 0 6px 0;">Görsel Kartınız Hazır!</h3>
    <p style="font-size: 13px; color: #718096; text-align: center; margin: 0 0 20px 0; font-family: 'Inter', sans-serif;">Aşağıdaki önizlemeden kontrol edebilir ve cihazınıza indirebilirsiniz.</p>
    
    <div id="sharePreviewImageContainer" style="width: 100%; border: 1px solid #E8E4DE; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 24px; text-align: center; background: #F8F7F4; line-height: 0;">
      <!-- Dynamic generated img will be placed here -->
    </div>
    
    <div style="display: flex; gap: 12px; width: 100%; font-family: 'Inter', sans-serif;">
      <button id="btnDownloadPreview" style="flex: 1; padding: 12px 20px; background: #C53030; color: #fff; border: none; border-radius: 6px; font-weight: 600; font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; transition: background 0.2s;">
        📥 Cihaza İndir
      </button>
      <button id="btnClosePreview" style="padding: 12px 20px; background: #E2E8F0; color: #4A5568; border: none; border-radius: 6px; font-weight: 600; font-size: 14px; cursor: pointer; transition: background 0.2s;">
        Kapat
      </button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Select all trigger buttons (both the inline one and the floating desktop one)
    const triggerButtons = document.querySelectorAll('#btnShareAsImage, .btnShareAsImage');
    const modal = document.getElementById('sharePreviewModal');
    const modalContent = document.getElementById('sharePreviewContent');
    const previewContainer = document.getElementById('sharePreviewImageContainer');
    const btnDownload = document.getElementById('btnDownloadPreview');
    const btnClose = document.getElementById('btnClosePreview');
    
    let currentDataUrl = null;

    if (triggerButtons.length === 0) return;

    // Open Modal and render image
    const openShareModal = async (btn) => {
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '⏳ Hazırlanıyor...';
      
      const shareCard = document.getElementById('shareCardTemplate');
      
      try {
        const canvas = await html2canvas(shareCard, {
          allowTaint: true,
          useCORS: true,
          scale: 2, // 2x high resolution
          backgroundColor: '#F8F7F4'
        });
        
        currentDataUrl = canvas.toDataURL('image/png');
        
        // Populate modal preview image
        previewContainer.innerHTML = '';
        const img = document.createElement('img');
        img.src = currentDataUrl;
        img.style.maxWidth = '100%';
        img.style.maxHeight = '50vh';
        img.style.objectFit = 'contain';
        img.alt = 'Paylaşım kartı önizleme';
        previewContainer.appendChild(img);
        
        // Show Modal
        modal.style.opacity = '1';
        modal.style.visibility = 'visible';
        modalContent.style.transform = 'scale(1)';
        
      } catch (error) {
        console.error('Share Image Generation Failed:', error);
        alert('Görsel kartı oluşturulurken bir hata oluştu.');
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    };

    // Close Modal helper
    const closeShareModal = () => {
      modal.style.opacity = '0';
      modal.style.visibility = 'hidden';
      modalContent.style.transform = 'scale(0.9)';
    };

    // Bind triggers
    triggerButtons.forEach(btn => {
      btn.addEventListener('click', () => openShareModal(btn));
    });

    // Bind close actions
    btnClose.addEventListener('click', closeShareModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeShareModal();
    });

    // Bind download action
    btnDownload.addEventListener('click', () => {
      if (!currentDataUrl) return;
      const link = document.createElement('a');
      link.download = '<%= article.slug %>-paylas.png';
      link.href = currentDataUrl;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      if (window.showToast) {
        window.showToast('Görsel kartı başarıyla indirildi!', 'success');
      }
    });
  });
</script>

<%- include('../partials/footer') %>
